<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp"
    android:background="#8CCA7F"
    tools:context=".Simple_Battle">

    <ImageButton
        android:id="@+id/btnMute"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Mute toggle"
        android:padding="8dp"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_volume_up"
        app:tint="#A0522D"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- FJENDEN (Øverst) -->
    <ImageView
        android:id="@+id/enemyImageView"
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:layout_marginTop="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/enemyHealthText"
        tools:src="@drawable/powerfront" />

    <TextView
        android:id="@+id/enemyHealthText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Enemy HP: 50/50"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@android:color/black"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="40dp"/>

    <!-- LOG (Midten) -->
    <TextView
        android:id="@+id/battleLogTextView"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Gør dig klar!"
        android:textAlignment="center"
        android:textSize="16sp"
        android:textStyle="italic"
        android:textColor="@android:color/black"
        android:background="#44FFFFFF"
        android:padding="8dp"
        app:layout_constraintBottom_toTopOf="@id/playerImageView"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/enemyImageView" />

    <!-- DIG SELV (Nederst) -->
    <ImageView
        android:id="@+id/playerImageView"
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:layout_marginBottom="10dp"
        app:layout_constraintBottom_toTopOf="@id/playerHealthText"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        tools:src="@drawable/powerback" />

    <TextView
        android:id="@+id/playerHealthText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:text="Your HP: 100/100"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@android:color/black"
        app:layout_constraintBottom_toTopOf="@id/attackButton"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <Button
        android:id="@+id/attackButton"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:backgroundTint="#A0522D"
        android:textColor="@android:color/white"
        android:text="ATTACK"
        app:layout_constraintBottom_toTopOf="@id/ChangeFighter" />

    <Button
        android:id="@+id/ChangeFighter"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginBottom="10dp"
        android:backgroundTint="#A0522D"
        android:textColor="@android:color/white"
        android:text="CHANGE FIGHTER"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>